KAFKA_BOOTSTRAP_SERVERS=techarch-kafka1.srv.lab.bthpny.alticeusa.net:9092
# Optional bake-time default for the web-ui "New job" template field
# (routeAppConfig.streamProperties.bootstrap.servers). Vite inlines this into
# the JS bundle at build time, so anything set here ships in the published
# image — leave EMPTY when building images for public registries / Docker Hub.
# Used by docker-compose.dev.yml and build_and_push.sh; for local
# `npm run dev` / `npm run build`, set in web-ui/.env instead.
VITE_EXAMPLE_KAFKA_BOOTSTRAP=
JOB_MANAGEMENT_API_PORT=8080
STREAMMUX_API_USERNAME=streammux
STREAMMUX_API_PASSWORD=change-me-now
STREAMMUX_WEB_PORT=8088
STREAMMUX_SITE_ID=site-a
STREAMMUX_INSTANCE_ID=orchestrator-1
STREAMMUX_TOPIC_JOB_DEFINITIONS=lab.optimum.experimental.streamlens.streammux.jobdefinitions
STREAMMUX_TOPIC_JOB_LEASES=lab.optimum.experimental.streamlens.streammux.jobleases
STREAMMUX_TOPIC_JOB_STATUS=lab.optimum.experimental.streamlens.streammux.jobstatus
STREAMMUX_TOPIC_JOB_EVENTS=lab.optimum.experimental.streamlens.streammux.jobevents
STREAMMUX_TOPIC_JOB_COMMANDS=lab.optimum.experimental.streamlens.streammux.jobcommands
# Compacted topic backing the job catalog API (key = catalog row id, value = JSON row, null = delete).
STREAMMUX_TOPIC_JOB_CATALOG=lab.optimum.experimental.streamlens.streammux.jobcatalog
STREAMMUX_ALLOWED_INPUT_TOPICS=net.optimum.monitoring.netscout.fixed.voicesip.json
STREAMMUX_ALLOWED_INPUT_TOPIC_PREFIXES=net.optimum.monitoring.
STREAMMUX_ALLOWED_OUTPUT_TOPICS=
STREAMMUX_ALLOWED_OUTPUT_TOPIC_PREFIXES=lab.optimum.experimental.streamlens.streammux.
