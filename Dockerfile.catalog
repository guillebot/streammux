FROM node:22-bookworm-slim

WORKDIR /app

COPY --chown=node:node job-catalog-api/package.json job-catalog-api/package-lock.json ./
RUN npm ci --omit=dev

COPY --chown=node:node job-catalog-api/server.mjs ./

ENV PORT=3000
ENV JOB_MANAGEMENT_API_URL=http://job-management-api:8080

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 CMD ["sh", "-c", "kill -0 1"]

USER node

CMD ["node", "server.mjs"]
