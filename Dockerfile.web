FROM node:22-alpine AS build

WORKDIR /app

COPY web-ui/package.json web-ui/package-lock.json ./
RUN npm ci

COPY web-ui/ ./
ARG VITE_EXAMPLE_KAFKA_BOOTSTRAP=
ENV VITE_EXAMPLE_KAFKA_BOOTSTRAP=${VITE_EXAMPLE_KAFKA_BOOTSTRAP}
RUN npm run build

FROM nginx:1.27-alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY web-ui/nginx/default.conf.template /etc/nginx/templates/default.conf.template
COPY web-ui/nginx/docker-entrypoint-streammux.sh /docker-entrypoint.d/40-streammux-verify-env.sh
RUN chmod +x /docker-entrypoint.d/40-streammux-verify-env.sh

ENV STREAMMUX_JOB_MANAGEMENT_API=job-management-api:8080
ENV STREAMMUX_JOB_CATALOG_API=job-catalog-api:3000

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 CMD ["wget", "-q", "-O", "/dev/null", "http://127.0.0.1/"]

USER nginx
